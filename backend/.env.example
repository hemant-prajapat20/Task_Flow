PORT=5000

# Your MongoDB Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/taskflow?retryWrites=true&w=majority

# Secret key for signing JWT tokens (can be any random secure string)
JWT_SECRET=your_super_secret_jwt_key_here

# Google Gemini API Key for the AI Task Estimator feature
# Get one free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here
